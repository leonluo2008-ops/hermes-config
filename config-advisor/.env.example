# config-advisor plugin environment configuration (TEMPLATE)
#
# Copy this file to .env inside this directory and fill in your values.
# The actual .env is gitignored — never commit real secrets.
#
# ─── Provider Configuration ──────────────────────────────────────────────────
# Active provider. Options:
#   - glm     (Default, uses Z.AI / GLM-5.2)
#   - minimax (uses MiniMax-M3)
#   - juxin   (uses gemini-3.5-flash)
#   - custom  (allows manual BASE_URL / MODEL overrides)
#
# CONFIG_ADVISOR_PROVIDER=glm

# ─── Custom Endpoint Overrides ───────────────────────────────────────────────
# Only needed if CONFIG_ADVISOR_PROVIDER is set to "custom", or to override
# specific parts of a pre-defined preset.
#
# CONFIG_ADVISOR_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# CONFIG_ADVISOR_MODEL=glm-5.2

# ─── Authentication ────────────────────────────────────────────────────────
# API key for the analysis endpoint.
# Resolution order:
#   1. CONFIG_ADVISOR_API_KEY  (plugin-specific, recommended)
#   2. ZAI_API_KEY             (Z.AI / GLM fallback)
#   3. GLM_API_KEY             (GLM fallback)
#   4. MINIMAX_CN_API_KEY      (Minimax fallback)
#   5. JUXIN_GEMINI_API_KEY    (Juxin fallback)
#
# CONFIG_ADVISOR_API_KEY=your-key-here

# ─── Tuning ────────────────────────────────────────────────────────────────
# Analysis request timeout in seconds (integer).
# Default: 60
# CONFIG_ADVISOR_TIMEOUT_S=60

# ─── Kill switch ───────────────────────────────────────────────────────────
# Set to any truthy value (1, true, yes, on) to disable the plugin entirely.
# CONFIG_ADVISOR_DISABLE=0
